{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "apastra-run-manifest-v1",
  "title": "Run Manifest Specification",
  "description": "Schema for a run manifest.",
  "type": "object",
  "properties": {
    "input_refs": { "type": "object", "description": "Input references" },
    "resolved_digests": { "type": "object", "description": "Resolved digests" },
    "timestamps": { "type": "object", "description": "Timestamps" },
    "harness_identifier": { "type": "string", "description": "Harness identifier" },
    "harness_version": { "type": "string", "description": "Harness version" },
    "model_ids": { "type": "array", "items": { "type": "string" }, "description": "Model IDs" },
    "sampling_config": { "type": "object", "description": "Sampling configuration" },
    "environment": { "type": "object", "description": "Environment metadata" },
    "status": { "type": "string", "description": "Run status" },
    "provenance": {
      "type": "object",
      "description": "SLSA-style provenance metadata representing the invocation of the evaluation run.",
      "properties": {
        "builder": {
          "type": "object",
          "description": "Identifies the builder.",
          "properties": {
            "id": { "type": "string", "description": "String URI identifying the builder." }
          }
        },
        "buildType": { "type": "string", "description": "String defining the build model." },
        "invocation": {
          "type": "object",
          "description": "Invocation configuration.",
          "properties": {
            "configSource": { "type": "object", "description": "Source of the configuration." },
            "environment": { "type": "object", "description": "Invocation environment." }
          }
        },
        "metadata": { "type": "object", "description": "Timestamps and build metadata." }
      }
    }
  },
  "required": ["input_refs", "resolved_digests", "timestamps", "harness_identifier", "harness_version", "model_ids", "sampling_config", "environment", "status"]
}
