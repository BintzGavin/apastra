{
  "id": "apastra/benchmarks/general-knowledge-v1",
  "name": "General Knowledge Benchmark",
  "description": "A suite to test the general knowledge of foundation models.",
  "datasets": [
    "apastra/datasets/trivia-qa-v1",
    "apastra/datasets/mmlu-core-v2"
  ],
  "evaluators": [
    "apastra/evaluators/exact-match",
    "apastra/evaluators/f1-score"
  ],
  "model_matrix": [
    "openai/gpt-4-turbo",
    "anthropic/claude-3-opus",
    "google/gemini-1.5-pro"
  ],
  "trials": 3,
  "budgets": {
    "cost": 50.0,
    "time": 3600
  },
  "thresholds": {
    "exact_match": 0.85,
    "f1_score": 0.90
  }
}