{
  "name": "apastra",
  "version": "1.1.0",
  "description": "PromptOps — version, evaluate, and ship AI prompts as disciplined software assets",
  "keywords": [
    "apastra",
    "promptops",
    "prompts",
    "evaluation",
    "benchmarking",
    "regression",
    "ai-skills",
    "agent-skills",
    "skills.sh",
    "claude",
    "cursor",
    "copilot"
  ],
  "homepage": "https://github.com/BintzGavin/apastra",
  "bugs": {
    "url": "https://github.com/BintzGavin/apastra/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BintzGavin/apastra.git"
  },
  "license": "Apache-2.0",
  "author": "Gavin Bintz",
  "bin": {
    "apastra": "bin/apastra"
  },
  "scripts": {
    "postinstall": "bash postinstall.sh"
  },
  "files": [
    "postinstall.sh",
    "bin/apastra",
    "SKILL.md",
    "baseline/**/*",
    "eval/**/*",
    "getting-started/**/*",
    "writing-evals/**/*",
    "red-team/**/*",
    "scaffold/**/*",
    "setup-ci/**/*",
    "trace/**/*",
    "docs/specs/provider-request-logging.md",
    "docs/guides/provider-request-logging.md",
    "validate/**/*",
    "promptops/runtime/**/*.py",
    "promptops/request_log/**/*.py",
    "promptops/hooks/**/*.py",
    "promptops/runs/**/*.py",
    "promptops/runs/**/*.sh",
    "promptops/resolver/**/*.py",
    "promptops/schemas/**/*.json",
    "promptops/schemas/**/*.md",
    "promptops/validators/**/*.sh",
    "promptops/harnesses/**/*",
    "promptops/policies/**/*",
    "promptops/__init__.py",
    "!**/__pycache__/**",
    "!**/*.pyc",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.1"
  },
  "overrides": {
    "brace-expansion": "^1.1.13",
    "fast-json-patch": "^3.1.1",
    "fast-uri": "^4.0.0",
    "js-yaml": "^5.1.0"
  }
}
